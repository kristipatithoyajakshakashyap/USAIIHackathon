# ============================================================
# PREVAIL .gitignore
# ============================================================

# --- Claude / assistant artifacts ---
**/CLAUDE.md
**/.claude/
AGENTS.md

# --- Python bytecode / caches ---
__pycache__/
*.py[cod]
*$py.class
*.so
.pytest_cache/
.mypy_cache/
.ruff_cache/

# --- Virtual environments ---
.venv/
venv/
env/
ENV/
backend/.venv/

# --- Logs ---
*.log
backend/install.log
backend/*.log

# --- Datasets & large media (downloaded / generated, not for git) ---
backend/data/
*.mp4
*.avi
*.mov
*.mkv
*.webm
_frame_check.png

# --- Model weights ---
# Large pretrained weights auto-download; the small trained head is kept.
backend/models/*.pt
!backend/models/risk_head.pt
*.onnx
*.engine

# --- HuggingFace / torch caches (usually outside repo, listed for safety) ---
.cache/
huggingface/

# --- SSL / TLS certificates ---
certs/
*.pem
*.crt
*.p12
*.pfx

# --- SQLite databases ---
*.db
*.sqlite
*.sqlite3

# --- Secrets / config ---
.env
.env.*
*.key
kaggle.json

# --- Node / frontend ---
# Yarn PnP / Berry
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

node_modules/
.next/
out/
dist/
build/
.turbo/

# Coverage
/coverage

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# TypeScript / Next.js build artifacts
*.tsbuildinfo
next-env.d.ts
.vercel

# --- OS / editor ---
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*~
